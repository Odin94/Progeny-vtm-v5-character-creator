{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "unicorn", "oxc"],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "no-constant-condition": "off",
        "no-unused-vars": "off"
    },
    "env": {
        "builtin": true,
        "browser": true,
        "es2024": true
    }
}
