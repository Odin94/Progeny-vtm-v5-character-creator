{
    "name": "progeny-backend",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "oxlint src scripts drizzle.config.ts vitest.config.ts",
        "lint:fix": "oxlint src scripts drizzle.config.ts vitest.config.ts --fix",
        "format": "oxfmt --write .",
        "fmt": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "test": "vitest",
        "test:run": "vitest run",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:studio": "drizzle-kit studio",
        "db:pull-backup": "node scripts/pull-db.mjs",
        "admin:promote-superadmin": "tsx scripts/promoteSuperadmin.ts"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^10.0.1",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/websocket": "^11.0.1",
        "@opentelemetry/api-logs": "^0.208.0",
        "@opentelemetry/exporter-logs-otlp-http": "^0.208.0",
        "@opentelemetry/resources": "^2.2.0",
        "@opentelemetry/sdk-logs": "^0.208.0",
        "@opentelemetry/sdk-node": "^0.208.0",
        "@workos-inc/node": "^7.79.3",
        "better-sqlite3": "^11.7.0",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.1.0",
        "nanoid": "^5.0.9",
        "posthog-node": "^5.29.2",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^24.0.0",
        "drizzle-kit": "^0.31.8",
        "node-gyp": "^12.3.0",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.19.2",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "better-sqlite3",
            "esbuild",
            "protobufjs"
        ]
    }
}
