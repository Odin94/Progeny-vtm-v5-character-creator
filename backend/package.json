{
    "name": "progeny-backend",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "pnpm run clean && tsc",
        "clean": "node scripts/cleanDist.mjs",
        "start": "node dist/index.js",
        "lint": "oxlint src scripts drizzle.config.ts vitest.config.ts",
        "lint:fix": "oxlint src scripts drizzle.config.ts vitest.config.ts --fix",
        "format": "oxfmt --write .",
        "fmt": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "test": "vitest",
        "test:run": "vitest run",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:studio": "drizzle-kit studio",
        "db:pull-backup": "node scripts/pull-db.mjs",
        "admin:promote-superadmin": "tsx scripts/promoteSuperadmin.ts"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/websocket": "^11.2.0",
        "@opentelemetry/api-logs": "^0.219.0",
        "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
        "@opentelemetry/resources": "^2.8.0",
        "@opentelemetry/sdk-logs": "^0.219.0",
        "@opentelemetry/sdk-node": "^0.219.0",
        "@workos-inc/node": "^9.3.0",
        "better-sqlite3": "^12.10.0",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.5",
        "nanoid": "^5.1.11",
        "posthog-node": "^5.38.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.9.1",
        "drizzle-kit": "^0.31.10",
        "node-gyp": "^13.0.0",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "overrides": {
            "@grpc/grpc-js": "1.14.4",
            "@opentelemetry/core": "2.8.0",
            "esbuild": "0.28.1",
            "protobufjs": "7.6.3",
            "tar": "7.5.16",
            "undici": "6.27.0",
            "vite": "7.3.5",
            "ws": "8.21.0"
        },
        "onlyBuiltDependencies": [
            "better-sqlite3",
            "esbuild",
            "protobufjs"
        ]
    }
}
